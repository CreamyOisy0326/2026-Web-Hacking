@model IEnumerable<PhotoMarket.Models.Photo>

@{
    ViewData["Title"] = "내 사진함";
}

<div class="container mt-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="display-5 fw-bold"><i class="bi bi-grid-fill me-2"></i>내 사진함</h1>
            <p class="text-muted">사용자님께서 판매 등록하신 사진들입니다.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-outline-primary">추가 등록</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center my-5 py-5 bg-light rounded shadow-sm">
            <i class="bi bi-camera-fill display-1 text-secondary opacity-25"></i>
            <h3 class="mt-4 text-secondary">등록된 사진이 없습니다.</h3>
            <p class="text-muted">첫 번째 사진을 올려서 판매를 시작해 보세요!</p>
            <a asp-action="Create" class="btn btn-primary mt-2">사진 업로드하기</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded bg-white">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th style="width: 150px;">미리보기</th>
                        <th>제목</th>
                        <th>가격</th>
                        <th class="text-center">작업</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>
                                <img src="@item.FilePath" class="rounded" style="width: 120px; height: 80px; object-fit: cover;">
                            </td>
                            <td>
                                <div class="fw-bold">@item.Title</div>
                                <div class="small text-muted text-truncate" style="max-width: 300px;">@item.Description</div>
                            </td>
                            <td class="text-success fw-bold">₩@item.Price.ToString("N0")</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light">상세</a>
                                <button class="btn btn-sm btn-outline-danger ms-1" disabled>삭제</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
