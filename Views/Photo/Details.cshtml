@model PhotoMarket.Models.Photo

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 shadow-sm rounded p-0 overflow-hidden bg-light">
            <img src="@Model.FilePath" class="img-fluid w-100" alt="@Model.Title">
        </div>
        <div class="col-lg-4 ps-lg-5 mt-4 mt-lg-0">
            <h1 class="fw-bold mb-3">@Model.Title</h1>
            <p class="text-muted mb-4" style="white-space: pre-wrap;">@Model.Description</p>
            
            <div class="card border-0 bg-light-subtle p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-secondary">판매 가격</span>
                    <span class="fs-2 fw-bold text-success">₩@Model.Price.ToString("N0")</span>
                </div>
                <div class="d-grid">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        if (ViewBag.IsSeller)
                        {
                            <button class="btn btn-secondary btn-lg shadow" disabled>내 사진입니다</button>
                        }
                        else if (ViewBag.AlreadyPurchased)
                        {
                            <a href="@Model.FilePath" download class="btn btn-success btn-lg shadow">이미 구매함: 다운로드</a>
                        }
                        else
                        {
                            <form asp-action="Purchase" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-primary btn-lg shadow w-100">지금 구매하기</button>
                            </form>
                        }
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg shadow">로그인하여 구매하기</a>
                    }
                </div>
            </div>

            <hr class="my-4">
            
            <div class="d-flex align-items-center text-muted">
                <div class="me-3">
                    <i class="bi bi-person-circle fs-2"></i>
                </div>
                <div>
                    <div class="small">판매자</div>
                    <div class="fw-bold text-dark">@(Model.Seller?.Email ?? "알 수 없음")</div>
                </div>
            </div>

            <div class="mt-5">
                <a asp-action="Index" class="text-decoration-none">
                    <i class="bi bi-arrow-left"></i> 목록으로 돌아가기
                </a>
            </div>
        </div>
    </div>
</div>
