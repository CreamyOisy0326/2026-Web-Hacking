@model PhotoMarket.Models.Board

@{
    ViewData["Title"] = "글 수정";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 p-4">
                <h2 class="fw-bold mb-4 text-center">게시글 수정</h2>
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-bold">제목</label>
                        <input asp-for="Title" class="form-control form-control-lg border-0 bg-light-subtle shadow-sm" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Content" class="form-label fw-bold">내용</label>
                        <textarea asp-for="Content" class="form-control border-0 bg-light-subtle shadow-sm" rows="10"></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light px-4">취소</a>
                        <button type="submit" class="btn btn-primary px-5">수정 완료</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
