@model IEnumerable<PhotoMarket.Models.Board>

@{
    ViewData["Title"] = "커뮤니티";
}

    <div class="container mt-4">
        <div class="row mb-4 align-items-center">
            <div class="col">
                <h1 class="display-5 fw-bold text-success"><i class="bi bi-chat-dots me-2"></i>커뮤니티</h1>
                <p class="text-muted">자유롭게 의견을 나누는 공간입니다.</p>
            </div>
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-success shadow-sm">
                    <i class="bi bi-pencil-square"></i> 글쓰기
                </a>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">제목</th>
                            <th>작성자</th>
                            <th>작성일</th>
                            <th class="text-end pe-4">관리</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td class="ps-4">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark fw-bold">@item.Title</a>
                                </td>
                                <td>@(item.Author?.UserName?.Split('@')[0] ?? "알 수 없음")</td>
                                <td class="text-muted small">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end pe-4">
                                    @if (User.Identity?.Name == item.Author?.UserName || User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary border-0">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('정말 삭제하시겠습니까?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
